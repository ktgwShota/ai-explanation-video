# ローカル開発用。コピーして .env.local を作成してください。

# --- Basic Auth ---
BASIC_AUTH_ENABLED=true
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=

# --- Supabase（本番: GitHub Secrets → deploy.yml が Cloudflare Pages に自動反映）---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Gemini ---
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- OAuth (Supabase Auth 連携) ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_ROOT_URL=http://localhost:3000

# --- 外部 API URL ---
OPENAI_WORKER_URL=
VOICEVOX_API_URL=
VIDEO_RENDER_API_URL=

# --- Cloudflare R2 ---
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# --- AWS S3 ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
